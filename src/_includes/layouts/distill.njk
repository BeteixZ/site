<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
    {% set ogType = "article" %}
    {% include "layouts/components/head.njk" %}
    
    <script src="https://distill.pub/template.v2.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
    <script src="https://cdn.jsdelivr.net/npm/vega-lite@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/vega-embed@v6"></script>

    {% for cssPath in 'css' | distillFiles %}
        <link rel="stylesheet" href="{{ cssPath }}">
    {% endfor %}

    {% for jsPath in 'js' | distillFiles %}
        <script src="{{ jsPath }}"></script>
    {% endfor %}

    <script async src="https://cdn.jsdelivr.net/npm/mathjax@2/MathJax.js?config=TeX-AMS-MML_HTMLorMML"></script>
    <script type="text/x-mathjax-config">
      MathJax.Hub.Config({tex2jax: {inlineMath: [['$','$'], ['\\(','\\)']]}});
    </script>
</head>
<body>
    <a href="#main-content" class="skip-link button">Skip to main content</a>

    <div class="main-wrapper">
        <main>
            <header class="main-title">
                <h1 class="site-title">
                    <a href="/">Bindow</a>
                </h1>
                <nav class="icons" aria-label="Social links">
                    <a class="icon" href="https://github.com/BeteixZ" target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                        <span>GitHub</span>
                    </a>
                </nav>
            </header>

            {% include "layouts/components/nav.njk" %}

            <div id="main-content" class="default-wrapper">
                {{ content | mark | safe }}
            </div>
        </main>

        <footer class="footer">
            <div class="container">
                <p>&copy; {{ page.date.getFullYear() if page.date else "2026" }} Bindow. Built with <a href="https://www.11ty.dev/" target="_blank" rel="noopener noreferrer">11ty</a>.</p>
            </div>
        </footer>
    </div>
    <script defer src="/js/music.js"></script>
</body>
</html>